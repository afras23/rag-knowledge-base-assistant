# Application
APP_NAME=rag-knowledge-base-assistant
APP_ENV=development
DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Database
# Must support asyncpg: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://appuser:apppass@localhost:5432/appdb

# CORS
# Optional comma-separated list of allowed origins for browser clients.
# Leave empty to restrict cross-origin access (except debug mode where CORS allows "*").
CORS_ALLOW_ORIGINS=http://localhost:8501,http://localhost:3000

